{
  "id": null,
  "title": "Twilio WhatsApp Service Dashboard",
  "tags": ["service-platform", "twilio", "whatsapp", "messaging"],
  "timezone": "browser",
  "schemaVersion": 35,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Service Status",
      "type": "stat",
      "targets": [
        {
          "expr": "max(up{job=\"twilio-whatsapp-service\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "color": "red",
                  "text": "DOWN"
                },
                "1": {
                  "color": "green",
                  "text": "UP"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.5
              }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Messages Sent",
      "type": "stat",
      "targets": [
        {
          "expr": "increase(twilio_messages_sent_total{job=\"twilio-whatsapp-service\"}[1h])",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "value"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 0
      }
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(twilio_errors_total{job=\"twilio-whatsapp-service\"}[5m])",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 0,
                "to": 0.01,
                "result": {
                  "color": "green",
                  "text": "Healthy"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0.01,
                "to": 0.05,
                "result": {
                  "color": "yellow",
                  "text": "Warning"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0.05,
                "to": 999,
                "result": {
                  "color": "red",
                  "text": "Critical"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "value"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      }
    },
    {
      "id": 4,
      "title": "Request Rate (5m)",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(twilio_requests_total{job=\"twilio-whatsapp-service\"}[5m])",
          "refId": "A",
          "legendFormat": "Requests/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "auto",
            "barAlignment": 0
          },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "calcs": ["mean", "max"]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 5,
      "title": "Response Time (p95)",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(twilio_request_duration_seconds_bucket{job=\"twilio-whatsapp-service\"}[5m]))",
          "refId": "A",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "auto",
            "barAlignment": 0
          },
          "unit": "s"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "calcs": ["mean", "max"]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    },
    {
      "id": 6,
      "title": "gRPC Connections",
      "type": "graph",
      "targets": [
        {
          "expr": "grpc_server_started_total{job=\"twilio-whatsapp-service\"}",
          "refId": "A",
          "legendFormat": "Connections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "auto",
            "barAlignment": 0
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      }
    },
    {
      "id": 7,
      "title": "Message Type Distribution",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum by (message_type) (rate(twilio_messages_sent_total{job=\"twilio-whatsapp-service\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{ message_type }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": []
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "values": ["value", "percent"]
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "single"
        },
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      }
    }
  ]
}
