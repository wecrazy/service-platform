{
  "id": null,
  "title": "LibreTranslate Service Dashboard",
  "tags": ["service-platform", "libretranslate"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "LibreTranslate Service Status",
      "type": "stat",
      "targets": [
        {
          "expr": "max(up{job=\"libretranslate-service\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "color": "red",
                  "text": "DOWN"
                },
                "1": {
                  "color": "green",
                  "text": "UP"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.5
              }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 3,
      "title": "Request Duration (95th percentile)",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(libretranslate_http_request_duration_seconds_bucket{job=\"libretranslate-service\"}[5m])) by (le, endpoint))",
          "refId": "A",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "yAxes": [
        {
          "unit": "seconds",
          "min": 0
        },
        {
          "unit": "short"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 4,
      "title": "Active Requests",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(libretranslate_http_requests_in_flight{job=\"libretranslate-service\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    },
    {
      "id": 5,
      "title": "Requests per Second by Status",
      "type": "graph",
      "targets": [
        {
          "expr": "sum(rate(libretranslate_http_request_duration_seconds_count{job=\"libretranslate-service\"}[5m])) by (status)",
          "refId": "A",
          "legendFormat": "Status {{status}}"
        }
      ],
      "yAxes": [
        {
          "unit": "reqps",
          "min": 0
        },
        {
          "unit": "short"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      }
    },
    {
      "id": 6,
      "title": "Average Request Duration",
      "type": "graph",
      "targets": [
        {
          "expr": "sum(rate(libretranslate_http_request_duration_seconds_sum{job=\"libretranslate-service\"}[5m])) / sum(rate(libretranslate_http_request_duration_seconds_count{job=\"libretranslate-service\"}[5m]))",
          "refId": "A",
          "legendFormat": "Average Duration"
        }
      ],
      "yAxes": [
        {
          "unit": "seconds",
          "min": 0
        },
        {
          "unit": "short"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "refresh": "5s",
  "schemaVersion": 38,
  "version": 1,
  "links": []
}
