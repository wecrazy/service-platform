{
  "id": null,
  "title": "Service Platform Overview",
  "tags": ["service-platform", "overview"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Service Health Overview",
      "type": "table",
      "targets": [
        {
          "expr": "up",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "API Service - Metrics Requests",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(promhttp_metric_handler_requests_total{job=\"api-service\",code=\"200\"}[5m])",
          "refId": "A",
          "legendFormat": "API Metrics Requests"
        }
      ],
      "gridPos": {
