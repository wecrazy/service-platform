{
  "id": null,
  "title": "N8N Service Dashboard",
  "tags": ["service-platform", "n8n"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "N8N Service Status",
      "type": "stat",
      "targets": [
        {
          "expr": "max(up{job=\"n8n-service\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "color": "red",
                  "text": "DOWN"
                },
                "1": {
                  "color": "green",
                  "text": "UP"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.5
              }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "CPU Usage",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(n8n_process_cpu_seconds_total{job=\"n8n-service\"}[5m])",
          "refId": "A",
          "legendFormat": "CPU"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },
    {
      "id": 3,
      "title": "Memory Usage",
      "type": "graph",
      "targets": [
        {
          "expr": "n8n_process_resident_memory_bytes{job=\"n8n-service\"}",
          "refId": "A",
          "legendFormat": "Memory"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 4,
      "title": "Event Loop Lag",
      "type": "graph",
      "targets": [
        {
          "expr": "n8n_nodejs_eventloop_lag_seconds{job=\"n8n-service\"}",
          "refId": "A",
          "legendFormat": "Lag"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "refresh": "5s",
  "schemaVersion": 38,
  "version": 1,
  "links": []
}
