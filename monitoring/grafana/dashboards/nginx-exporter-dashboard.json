{
  "id": null,
  "title": "Nginx Exporter Dashboard",
  "tags": ["service-platform", "nginx", "proxy", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 35,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Exporter Status",
      "type": "stat",
      "targets": [
        {
          "expr": "max(up{job=\"nginx-exporter\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "color": "red",
                  "text": "DOWN"
                },
                "1": {
                  "color": "green",
                  "text": "UP"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.5
              }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Active Connections",
      "type": "stat",
      "targets": [
        {
          "expr": "max(nginx_connections_active{job=\"nginx-exporter\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "orange",
                "value": 1000
              },
              {
                "color": "red",
                "value": 2000
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "value"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 0
      }
    },
    {
      "id": 3,
      "title": "Requests/sec",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(nginx_http_requests_total{job=\"nginx-exporter\"}[1m])",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "reqps"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "value"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      }
    },
    {
      "id": 4,
      "title": "Connection States",
      "type": "graph",
      "targets": [
        {
          "expr": "nginx_connections_reading{job=\"nginx-exporter\"}",
          "refId": "A",
          "legendFormat": "Reading"
        },
        {
          "expr": "nginx_connections_writing{job=\"nginx-exporter\"}",
          "refId": "B",
          "legendFormat": "Writing"
        },
        {
          "expr": "nginx_connections_waiting{job=\"nginx-exporter\"}",
          "refId": "C",
          "legendFormat": "Waiting"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "auto",
            "barAlignment": 0
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "calcs": ["mean", "max"]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 5,
      "title": "HTTP Request Rate (5m)",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(nginx_http_requests_total{job=\"nginx-exporter\"}[5m])",
          "refId": "A",
          "legendFormat": "Requests/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "auto",
            "barAlignment": 0
          },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "calcs": ["mean", "max"]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    },
    {
      "id": 6,
      "title": "Connections Accepted vs Handled",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(nginx_connections_accepted_total{job=\"nginx-exporter\"}[5m])",
          "refId": "A",
          "legendFormat": "Accepted/sec"
        },
        {
          "expr": "rate(nginx_connections_handled_total{job=\"nginx-exporter\"}[5m])",
          "refId": "B",
          "legendFormat": "Handled/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "auto",
            "barAlignment": 0
          },
          "unit": "conns"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "calcs": ["mean", "max"]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      }
    },
    {
      "id": 7,
      "title": "Active Connections Trend",
      "type": "graph",
      "targets": [
        {
          "expr": "nginx_connections_active{job=\"nginx-exporter\"}",
          "refId": "A",
          "legendFormat": "Active Connections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisPlacement": "auto",
            "barAlignment": 0,
            "fillOpacity": 10
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "calcs": ["mean", "max", "min"]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      }
    }
  ]
}
