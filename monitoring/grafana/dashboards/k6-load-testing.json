{
  "title": "k6 Load Testing Dashboard",
  "tags": [
    "k6",
    "load-testing",
    "performance"
  ],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 0,
  "refresh": "5s",
  "panels": [
    {
      "type": "graph",
      "title": "HTTP Request Duration",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(k6_http_req_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(k6_http_req_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "yaxes": [
        {
          "format": "ms",
          "label": "Duration"
        },
        {
          "format": "short"
        }
      ],
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "legend": {
        "show": true,
        "alignAsTable": true,
        "avg": true,
        "current": true,
        "max": true,
        "values": true
      }
    },
    {
      "type": "graph",
      "title": "Virtual Users (VUs)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "k6_vus",
          "legendFormat": "Active VUs",
          "refId": "A"
        },
        {
          "expr": "k6_vus_max",
          "legendFormat": "Max VUs",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "short",
          "label": "VUs"
        },
        {
          "format": "short"
        }
      ],
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "legend": {
        "show": true,
        "alignAsTable": true,
        "current": true,
        "max": true,
        "values": true
      }
    },
    {
      "type": "graph",
      "title": "Request Rate",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(k6_http_reqs_total[1m]))",
          "legendFormat": "Requests/sec",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "reqps",
          "label": "Requests per second"
        },
        {
          "format": "short"
        }
      ],
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "legend": {
        "show": true,
        "alignAsTable": true,
        "avg": true,
        "current": true,
        "max": true,
        "values": true
      }
    },
    {
      "type": "graph",
      "title": "Error Rate",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(k6_http_req_failed_total[1m])) / sum(rate(k6_http_reqs_total[1m])) * 100",
          "legendFormat": "Error Rate %",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "percent",
          "label": "Error %",
          "max": 100,
          "min": 0
        },
        {
          "format": "short"
        }
      ],
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "alert": {
        "name": "High Error Rate",
        "conditions": [
          {
            "evaluator": {
              "params": [
                5
              ],
              "type": "gt"
            },
            "operator": {
              "type": "and"
            },
            "query": {
              "params": [
                "A",
                "5m",
                "now"
              ]
            },
            "reducer": {
              "params": [],
              "type": "avg"
            },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "frequency": "60s",
        "handler": 1,
        "message": "k6 load test error rate exceeds 5%",
        "noDataState": "no_data",
        "notifications": []
      },
      "legend": {
        "show": true,
        "alignAsTable": true,
        "avg": true,
        "current": true,
        "max": true,
        "values": true
      },
      "thresholds": [
        {
          "value": 1,
          "colorMode": "critical",
          "op": "gt",
          "fill": true,
          "line": true
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Requests",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(k6_http_reqs_total)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "blue",
                "value": 10000
              }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "type": "stat",
      "title": "Failed Requests",
      "gridPos": {
        "x": 6,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(k6_http_req_failed_total)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "type": "stat",
      "title": "Avg Response Time",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(k6_http_req_duration_seconds_sum[5m])) / sum(rate(k6_http_req_duration_seconds_count[5m])) * 1000",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          },
          "unit": "ms",
          "decimals": 2
        }
      }
    },
    {
      "type": "stat",
      "title": "Current VUs",
      "gridPos": {
        "x": 18,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "k6_vus",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "type": "graph",
      "title": "Iterations",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(k6_iterations_total[1m]))",
          "legendFormat": "Iterations/sec",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "short",
          "label": "Iterations per second"
        },
        {
          "format": "short"
        }
      ],
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "legend": {
        "show": true,
        "alignAsTable": true,
        "avg": true,
        "current": true,
        "max": true,
        "values": true
      }
    },
    {
      "type": "graph",
      "title": "Data Sent/Received",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(k6_data_sent_bytes[1m]))",
          "legendFormat": "Data Sent",
          "refId": "A"
        },
        {
          "expr": "sum(rate(k6_data_received_bytes[1m]))",
          "legendFormat": "Data Received",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "Bps",
          "label": "Bytes per second"
        },
        {
          "format": "short"
        }
      ],
      "lines": true,
      "fill": 1,
      "linewidth": 2,
      "legend": {
        "show": true,
        "alignAsTable": true,
        "avg": true,
        "current": true,
        "max": true,
        "values": true
      }
    },
    {
      "type": "table",
      "title": "Request Stats by Endpoint",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (name) (rate(k6_http_reqs_total[5m]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "sum by (name) (rate(k6_http_req_failed_total[5m])) / sum by (name) (rate(k6_http_reqs_total[5m])) * 100",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (name, le) (rate(k6_http_req_duration_seconds_bucket[5m]))) * 1000",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "name": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3
            },
            "renameByName": {
              "name": "Endpoint",
              "Value #A": "Req/s",
              "Value #B": "Error %",
              "Value #C": "p95 (ms)"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Req/s",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Error %"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 1
                    },
                    {
                      "color": "red",
                      "value": 5
                    }
                  ]
                }
              },
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "p95 (ms)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 500
                    },
                    {
                      "color": "red",
                      "value": 1000
                    }
                  ]
                }
              },
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Req/s"
            },
            "properties": [
              {
                "id": "unit",
                "value": "reqps"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Test Start/End",
        "datasource": "Prometheus",
        "enable": true,
        "expr": "changes(k6_vus[1m]) > 0",
        "iconColor": "blue",
        "step": "1m",
        "tagKeys": "test",
        "textFormat": "Test Phase Change",
        "titleFormat": "k6 Test Event"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "style": "dark",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m"
    ]
  },
  "uid": "k6-load-testing"
}
