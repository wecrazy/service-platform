{
  "id": null,
  "title": "Scheduler Service Dashboard",
  "tags": ["service-platform", "scheduler"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Scheduler Service Status",
      "type": "stat",
      "targets": [
        {
          "expr": "up{job=\"scheduler-service\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Metrics Endpoint Requests",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(promhttp_metric_handler_requests_total{job=\"scheduler-service\",code=\"200\"}[5m])",
          "refId": "A",
          "legendFormat": "Successful Requests"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },
    {
      "id": 3,
      "title": "Goroutines",
      "type": "graph",
      "targets": [
        {
          "expr": "go_goroutines{job=\"scheduler-service\"}",
          "refId": "A",
          "legendFormat": "Goroutines"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 4,
      "title": "Memory Usage",
      "type": "graph",
      "targets": [
        {
          "expr": "go_memstats_alloc_bytes{job=\"scheduler-service\"}",
          "refId": "A",
          "legendFormat": "Heap Allocated"
        },
        {
          "expr": "process_resident_memory_bytes{job=\"scheduler-service\"}",
          "refId": "B",
          "legendFormat": "Resident Memory"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    },
    {
      "id": 5,
      "title": "CPU Usage",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"scheduler-service\"}[5m]) * 100",
          "refId": "A",
          "legendFormat": "CPU Usage %"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      }
    },
    {
      "id": 6,
      "title": "GC Duration",
      "type": "graph",
      "targets": [
        {
          "expr": "go_gc_duration_seconds{job=\"scheduler-service\",quantile=\"0.5\"}",
          "refId": "A",
          "legendFormat": "GC Duration (median)"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      }
    },
    {
      "id": 7,
      "title": "Heap Objects",
      "type": "graph",
      "targets": [
        {
          "expr": "go_memstats_heap_objects{job=\"scheduler-service\"}",
          "refId": "A",
          "legendFormat": "Heap Objects"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      }
    },
    {
      "id": 8,
      "title": "Network I/O",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(process_network_receive_bytes_total{job=\"scheduler-service\"}[5m])",
          "refId": "A",
          "legendFormat": "Bytes Received"
        },
        {
          "expr": "rate(process_network_transmit_bytes_total{job=\"scheduler-service\"}[5m])",
          "refId": "B",
          "legendFormat": "Bytes Transmitted"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "refresh": "5s",
  "schemaVersion": 38,
  "version": 0,
  "links": []
}